# SkillSwap Network — Backend Environment Variables
# Copy this to .env and fill in your values

# ── Database ──
DATABASE_URL=postgresql+asyncpg://postgres:Password@localhost:5432/skillswap_db

# ── JWT Auth ──
SECRET_KEY=super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── App ──
ENVIRONMENT=development
# Change to: production (for Render/cloud deploy)

# ── CORS ──
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# On Vercel: ALLOWED_ORIGINS=https://your-app.vercel.app
